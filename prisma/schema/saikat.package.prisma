model packageBanner {
  id        String   @id @default(cuid())
  site      SiteType

  packageBannerId        String?
  packageBanner          FileInstance? @relation("packageBanner", fields: [packageBannerId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

    @@map("package_banners")
}