model Boats {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  price       Float
  description String?

  // * Specifications
  buildYear Int
  make      String
  model     String

  fuelType  BoatFuelType
  class     BoatClass
  material  BoatMaterial
  condition BoatCondition

  length Float // total feet, e.g., 36.5 = 36'6"
  beam   Float // total feet
  draft  Float // total feet

  enginesNumber Int
  cabinsNumber  Int
  headsNumber   Int

  // * Address Information
  city  String
  state String
  zip   String

  // * Extra details
  extraDetails Json? // Stores array of { key, value }

  status BoatListingStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // * Media
  videoURL String?

  engines BoatEngine[]
  images  BoatImage[]

  @@map("boats")
}

enum BoatListingStatus {
  ONBOARDING_PENDING
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  SOLD
}

model BoatEngine {
  id String @id @default(uuid())

  hours      Int
  horsepower Int

  make  String
  model String

  fuelType      BoatFuelType
  propellerType BoatPropellerType

  boatId String
  boat   Boats  @relation(fields: [boatId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("boat_engines")
}

model BoatImage {
  id String @id @default(uuid())

  boatId String
  boat   Boats  @relation(fields: [boatId], references: [id], onDelete: Cascade)

  fileId String
  file   FileInstance @relation(fields: [fileId], references: [id], onDelete: Cascade)

  imageType BoatImageType

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("boat_images")
}

enum BoatCondition {
  NEW
  USED
  REFURBISHED
  DAMAGED
}

enum BoatFuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
  OTHER
}

enum BoatClass {
  SAILBOAT
  MOTORBOAT
  YACHT
  FISHING
  PONTOON
  SPEEDBOAT
  CATAMARAN
  OTHER
}

enum BoatMaterial {
  FIBERGLASS
  ALUMINUM
  WOOD
  STEEL
  CARBON_FIBER
  PLASTIC
  OTHER
}

enum BoatPropellerType {
  FIXED
  FOLDING
  FEATHERING
  SURFACE_PIERCING
  CONTROLLABLE_PITCH
  OTHER
}

enum BoatImageType {
  COVER
  GALLERY
}
