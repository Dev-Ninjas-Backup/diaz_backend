model FileInstance {
  id String @id @default(uuid())

  filename         String
  originalFilename String
  path             String
  url              String
  fileType         FileType @default(any)
  mimeType         String
  size             Int

  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @default(now()) @updatedAt
  pageBannersBackground PageBanner[] @relation("BackgroundFile")

  blog       Blog[]      @relation("blogImage")
  boatImages BoatImage[]

  contactTopImages    ContactPage? @relation("contactTopImage")
  contactBottomImages ContactPage? @relation("contactBottomImage")

  featuredBrandLogos FeaturedBrands[] @relation("FeaturedBrandLogo")

  blogs           Blog[]
  settings        Setting[]
  packageBanners  packageBanner[]  @relation("packageBanner")
  aiSearchBanners AiSearchBanner[] @relation("AiSearchBanner")
  categoryImages  Category[]        @relation("CategoryImage")

  whyUsImage1 WhyUs[] @relation("WhyUsImage1")
  whyUsImage2 WhyUs[] @relation("WhyUsImage2")
  whyUsImage3 WhyUs[] @relation("WhyUsImage3")

  @@map("file_instances")
}

enum FileType {
  image
  docs
  link
  document
  any
  video
  audio
}
