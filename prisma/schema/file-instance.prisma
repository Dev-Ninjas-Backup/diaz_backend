model FileInstance {
  id String @id @default(uuid())

  filename         String
  originalFilename String
  path             String
  url              String
  fileType         FileType @default(any)
  mimeType         String
  size             Int

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  pageBanners PageBanner[] @relation("LogoFile")
  pageBannersBackground PageBanner[] @relation("BackgroundFile")

  blog Blog[] @relation("blogImage")
  boatImages BoatImage[]

  contactTopImages ContactPage? @relation("contactTopImage")
  contactBottomImages ContactPage? @relation("contactBottomImage")

  aboutPageTopImages AboutPage?    @relation("AboutPageTopImage")
  aboutPageBottonImages AboutPage? @relation("AboutPageBottomImage")

  @@map("file_instances")

  blogs Blog[]
  settings Setting[]
}

enum FileType {
  image
  docs
  link
  document
  any
  video
  audio
}
