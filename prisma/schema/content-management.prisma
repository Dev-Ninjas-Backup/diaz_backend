model AboutPage {
  id String @id @default(uuid())

  site             SiteType @default(FLORIDA)
  aboutTitle       String?  @db.VarChar(255)
  aboutDescription String?
  mission          String?
  vision           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@map("aboutpage")
}

model ContactPage {
  id String @id @default(uuid())

  site               SiteType @default(FLORIDA)
  contactTitle       String?  @db.VarChar(255)
  contactDescription String?

  contactTopImageId String?       @unique
  contactTopImage   FileInstance? @relation("contactTopImage", fields: [contactTopImageId], references: [id])

  contactBottomImageId String?       @unique
  contactBottomImage   FileInstance? @relation("contactBottomImage", fields: [contactBottomImageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@map("contactpage")
}

model PrivacyPolicy {
  id String @id @default(uuid())

  site               SiteType @default(FLORIDA)
  privacyTitle       String   @db.VarChar(255)
  privacyDescription String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([site])
  @@map("privacypolicy")
}

model TermsOfServices {
  id String @id @default(uuid())

  site             SiteType @default(FLORIDA)
  termsTitle       String   @db.VarChar(255)
  termsDescription String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([site])
  @@map("terms_of_services")
}

model FooterSettings {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  // Company Information
  companyName        String? @db.VarChar(255)
  companyDescription String?

  // Quick Links
  quickLinks Json? // Array of { label: string, url: string }

  // Need Help? - Policies
  policyLinks Json? // Array of { label: string, url: string }

  // Contact Information
  phone String? @db.VarChar(50)
  email String? @db.VarChar(255)

  // Social Media Links
  socialMediaLinks Json? // Array of { platform: string, url: string, icon: string }

  // Copyright Text
  copyrightText String? @default("© Copyright 2025 by Jupiter Marine Sales. All rights reserved.")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@map("footer_settings")
}

model EmailSubscription {
  id String @id @default(uuid())

  email String   @db.VarChar(255)
  site  SiteType @default(FLORIDA)

  isActive Boolean @default(true)

  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, site])
  @@index([email])
  @@index([site])
  @@map("email_subscriptions")
}

model FAQ {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  title    String
  subtitle String?

  // Array of Q&A objects stored as JSON
  questions Json // Array of { question: string, answer: string }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([site])
  @@map("faqs")
}

model WhyUs {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  title       String  @db.VarChar(255)
  description String? @db.Text

  // Statistics
  excellence       String? @db.VarChar(255) // e.g., "Years of Excellence"
  boatsSoldPerYear String? @db.VarChar(100) // e.g., "1000+"
  listingViewed    String? @db.VarChar(100) // e.g., "10M+"

  // Button
  buttonText String? @db.VarChar(100)
  buttonLink String? @db.VarChar(500)

  // Images (3 images)
  image1Id String?       @unique
  image1   FileInstance? @relation("WhyUsImage1", fields: [image1Id], references: [id], onDelete: SetNull)

  image2Id String?       @unique
  image2   FileInstance? @relation("WhyUsImage2", fields: [image2Id], references: [id], onDelete: SetNull)

  image3Id String?       @unique
  image3   FileInstance? @relation("WhyUsImage3", fields: [image3Id], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@index([site])
  @@map("why_us")
}

model OurStory {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  title       String  @db.VarChar(255)
  description String? @db.Text

  // Images (5 images)
  image1Id String?       @unique
  image1   FileInstance? @relation("OurStoryImage1", fields: [image1Id], references: [id], onDelete: SetNull)

  image2Id String?       @unique
  image2   FileInstance? @relation("OurStoryImage2", fields: [image2Id], references: [id], onDelete: SetNull)

  image3Id String?       @unique
  image3   FileInstance? @relation("OurStoryImage3", fields: [image3Id], references: [id], onDelete: SetNull)

  image4Id String?       @unique
  image4   FileInstance? @relation("OurStoryImage4", fields: [image4Id], references: [id], onDelete: SetNull)

  image5Id String?       @unique
  image5   FileInstance? @relation("OurStoryImage5", fields: [image5Id], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fileInstances FileInstance[] @relation("OurStories")

  @@unique([site])
  @@index([site])
  @@map("our_story")
}

model MissionVision {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  mission           String  @db.VarChar(255)
  description       String? @db.Text
  visionDescription String? @db.Text

  // Images (3 images)
  image1Id String?       @unique
  image1   FileInstance? @relation("MissionVisionImage1", fields: [image1Id], references: [id], onDelete: SetNull)

  image2Id String?       @unique
  image2   FileInstance? @relation("MissionVisionImage2", fields: [image2Id], references: [id], onDelete: SetNull)

  image3Id String?       @unique
  image3   FileInstance? @relation("MissionVisionImage3", fields: [image3Id], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fileInstances FileInstance[] @relation("MissionVisions")

  @@unique([site])
  @@index([site])
  @@map("mission_vision")
}

model WhatSetsUsApart {
  id String @id @default(uuid())

  site SiteType @default(FLORIDA)

  title       String  @db.VarChar(255)
  description String? @db.Text

  // Statistics
  yearsOfYachtingExcellence String? @db.VarChar(100) // e.g., "20+"
  boatsSoldIn2024           String? @db.VarChar(100) // e.g., "1000+"
  listingsViewedMonthly     String? @db.VarChar(100) // e.g., "10M+"

  // Images (2 images)
  image1Id String?       @unique
  image1   FileInstance? @relation("WhatSetsUsApartImage1", fields: [image1Id], references: [id], onDelete: SetNull)

  image2Id String?       @unique
  image2   FileInstance? @relation("WhatSetsUsApartImage2", fields: [image2Id], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fileInstances FileInstance[] @relation("WhatSetsUsAparts")

  @@unique([site])
  @@index([site])
  @@map("what_sets_us_apart")
}
