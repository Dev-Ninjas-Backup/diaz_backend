model AboutPage {
  id String @id @default(uuid())

  site              SiteType @default(FLORIDA)
  aboutTitle        String?  @db.VarChar(255)
  aboutDescription  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@map("aboutpage")
}

model ContactPage {
  id String @id @default(uuid())

  site                SiteType @default(FLORIDA)
  contactTitle        String?  @db.VarChar(255)
  contactDescription  String?

  contactTopImageId String?       @unique
  contactTopImage   FileInstance? @relation("contactTopImage", fields: [contactTopImageId], references: [id])

  contactBottomImageId String?       @unique
  contactBottomImage   FileInstance? @relation("contactBottomImage", fields: [contactBottomImageId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([site])
  @@map("contactpage")
}

model PrivacyPolicy {
  id String @id @default(uuid())

  site              SiteType @default(FLORIDA)
  privacyTitle      String   @db.VarChar(255)
  privacyDescription String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([site])
  @@map("privacypolicy")
}

model TermsOfServices {
  id String @id @default(uuid())

  site              SiteType @default(FLORIDA)
  termsTitle        String   @db.VarChar(255)
  termsDescription  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([site])
  @@map("terms_of_services")
}
