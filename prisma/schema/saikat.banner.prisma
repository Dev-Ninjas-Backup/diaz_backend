model PageBanner {
  id        String   @id @default(cuid())
  page      PageType
  site      SiteType

  bannerTitle   String
  subtitle      String?

  logoId        String?
  logo          FileInstance? @relation("LogoFile", fields: [logoId], references: [id], onDelete: SetNull)

  backgroundId  String?
  background    FileInstance? @relation("BackgroundFile", fields: [backgroundId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

    @@map("page_banners")
}

enum PageType {
  HOME
  BLOG
  CONTACT
  SEARCH
  PRIVACY_POLICY
  TERMS_AND_CONDITION
}

enum SiteType {
  FLORIDA
  JUPITER
}
