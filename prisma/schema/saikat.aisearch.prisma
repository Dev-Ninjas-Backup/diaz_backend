model AiSearchBanner {
  id        String   @id @default(cuid())
  site      SiteType

  aiSearchBannerId        String?
  aiSearchBanner          FileInstance? @relation("AiSearchBanner", fields: [aiSearchBannerId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

    @@map("ai_search_banners")
}