api.floridayachttrader.com {
  # PgAdmin route - proxy without stripping prefix
  handle /pgadmin* {
    reverse_proxy pgadmin:80 {
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
      header_up X-Script-Name /pgadmin
    }
  }

  reverse_proxy /socket.io* server:5051

  @api {
    not path /socket.io*
    not path /pgadmin*
  }

  handle @api {
    # Allow up to 500MB upload
    request_body {
      max_size 500MB
    }

    reverse_proxy server:5051 {
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
      header_up Host {host}
    }
  }
}